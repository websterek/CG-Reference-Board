<Application
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CGReferenceBoard.App"
    RequestedThemeVariant="Dark"
>
    <Application.Resources>
        <!-- ═══ Accent Color System ═══ -->
        <Color x:Key="AccentColor">#44AAFF</Color>
        <Color x:Key="AccentColorLight">#66BBFF</Color>
        <Color x:Key="AccentColorDark">#2288DD</Color>
        <Color x:Key="AccentColorDim">#1144AAFF</Color>

        <SolidColorBrush
            x:Key="AccentBrush"
            Color="{StaticResource AccentColor}"
        />
        <SolidColorBrush
            x:Key="AccentBrushLight"
            Color="{StaticResource AccentColorLight}"
        />
        <SolidColorBrush
            x:Key="AccentBrushDark"
            Color="{StaticResource AccentColorDark}"
        />
        <SolidColorBrush
            x:Key="AccentBrushDim"
            Color="{StaticResource AccentColorDim}"
        />

        <!-- ═══ Surface Colors ═══ -->
        <Color x:Key="SurfaceColor">#1E1E1E</Color>
        <Color x:Key="SurfaceColorLight">#2A2A2A</Color>
        <Color x:Key="SurfaceColorDark">#121212</Color>
        <Color x:Key="BorderColorSubtle">#333333</Color>
        <Color x:Key="BorderColorMedium">#444444</Color>

        <SolidColorBrush
            x:Key="SurfaceBrush"
            Color="{StaticResource SurfaceColor}"
        />
        <SolidColorBrush
            x:Key="SurfaceBrushLight"
            Color="{StaticResource SurfaceColorLight}"
        />
        <SolidColorBrush
            x:Key="SurfaceBrushDark"
            Color="{StaticResource SurfaceColorDark}"
        />
        <SolidColorBrush
            x:Key="BorderBrushSubtle"
            Color="{StaticResource BorderColorSubtle}"
        />
        <SolidColorBrush
            x:Key="BorderBrushMedium"
            Color="{StaticResource BorderColorMedium}"
        />

        <!-- ═══ Text Colors ═══ -->
        <SolidColorBrush x:Key="TextPrimary" Color="#EEEEEE" />
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA" />
        <SolidColorBrush x:Key="TextTertiary" Color="#777777" />
        <SolidColorBrush x:Key="TextDanger" Color="#FF6666" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ═══ Global Font ═══ -->
        <Style Selector=":is(TemplatedControl)">
            <Setter
                Property="FontFamily"
                Value="Inter, avares://Avalonia.Fonts.Inter/Assets#Inter"
            />
        </Style>
        <Style Selector="TextBlock">
            <Setter
                Property="FontFamily"
                Value="Inter, avares://Avalonia.Fonts.Inter/Assets#Inter"
            />
        </Style>
    </Application.Styles>
</Application>
