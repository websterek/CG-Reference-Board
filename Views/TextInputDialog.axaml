<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:CGReferenceBoard.Views"
    x:Class="CGReferenceBoard.Views.TextInputDialog"
    x:DataType="views:TextInputDialog"
    Title="New Board"
    Width="360"
    Height="160"
    WindowStartupLocation="CenterOwner"
    CanResize="False"
    Background="#1E1E1E"
    WindowDecorations="None"
>
    <Border CornerRadius="8" Background="#121212" BorderBrush="#3D3D3D" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto" Margin="20">
            <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
            <TextBox
                Grid.Row="1"
                x:Name="InputTextBox"
                PlaceholderText="Enter board name..."
                Background="#2D2D2D"
                BorderBrush="#3D3D3D"
                Foreground="White"
                Margin="0,0,0,16"
            />
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Content="Cancel" Click="Cancel_Click" Background="Transparent" Foreground="{StaticResource TextSecondary}" BorderBrush="{StaticResource BorderBrushMedium}" Padding="16,8"/>
                <Button Content="Create" Click="Create_Click" Background="{StaticResource AccentBrush}" Foreground="White" Padding="16,8"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>